# 集成测试环境配置 / Integration Test Environment Config
# 用法 / Usage: source script/test.env && bash script/run_integration_tests.sh

# --- 测试账号 / Test Account ---
# 由 ensure_test_user.escript 自动创建（如不存在）
TEST_PHONE=13900001002
TEST_PASSWORD=admin888

# --- PostgreSQL ---
PGHOST=127.0.0.1
PGPORT=4323
PGUSER=imboy_user
PGDATABASE=imboy_v1
PGPASSWORD=abc54321

# --- Erlang 后端 / Backend ---
IMBOYENV=local
HTTP_PORT=9800
BACKEND_STARTUP_TIMEOUT=60    # 后端启动等待秒数
API_BASE_URL=http://127.0.0.1:9800   # dart test test/api/ 使用

# --- Flutter 测试 / Flutter Test ---
TEST_DEVICE=macos             # macos | android
APP_ENV=local_office          # Flutter app 环境

# --- 测试账号 UID（用于后端 smoke test）---
SMOKE_FROM=1000000051         # Alice
SMOKE_TO=1000000056           # Bob
